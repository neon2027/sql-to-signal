{
    "name": "laravelldone/sql-to-signal",
    "description": "Call ->toSignal() on Eloquent/Query Builder chains to get a reactive Signal object for Livewire 3/4 and Alpine.js",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "livewire", "alpinejs", "reactive", "signal", "eloquent"],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "livewire/livewire": "^3.0|^4.0",
        "spatie/laravel-package-tools": "^1.9"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/larastan": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Laravelldone\\SqlToSignal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laravelldone\\SqlToSignal\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laravelldone\\SqlToSignal\\SqlToSignalServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
